# ===== AMBIENTE =====
NODE_ENV=development
PORT=3000

# ===== URLs =====
API_URL=http://localhost:3000

# ===== BANCO LOCAL (Docker: docker compose -f docker-compose.dev.yml up -d) =====
DATABASE_URL=postgresql://yatsunami_dev:yatsunami_dev_local@localhost:5434/yatsunami_dev
DIRECT_URL=postgresql://yatsunami_dev:yatsunami_dev_local@localhost:5434/yatsunami_dev

# ===== BANCO PRODUÇÃO (VPS) =====
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/yatsunami_db

# ===== STORAGE =====
# local = disco (dev) | r2 = Cloudflare R2 (produção)
STORAGE_BACKEND=local
UPLOADS_PATH=/var/www/yatsunami/uploads
ASSETS_PUBLIC_URL=https://media.yatsunami.com.br

# ===== Cloudflare R2 =====
CLOUDFLARE_S3_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_ACCESS_KEY=
CLOUDFLARE_SECRET_KEY=
R2_BUCKET=yatsunami
R2_PUBLIC_BASE_URL=https://media.yatsunami.com.br

# ===== JWT =====
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ===== MAIL (Brevo) =====
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@yatsunami.com.br
MAIL_FROM_NAME=Yatsunami
